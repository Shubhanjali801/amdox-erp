// F-12: OFFLINE / PWA SUPPORT
// Owner: M6
// ============================================================

model SyncQueue {
  id          String      @id @default(uuid())
  tenantId    String
  userId      String
  operation   String      // CREATE, UPDATE, DELETE
  resource    String      // invoice, leave_request, attendance
  payload     Json
  status      SyncStatus  @default(PENDING)
  syncedAt    DateTime?
  errorMsg    String?
  createdAt   DateTime    @default(now())

  @@index([tenantId, userId, status])
  @@map("sync_queue")
}

