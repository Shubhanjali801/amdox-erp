// F-07: PROJECT MANAGEMENT
// Owner: M4
// ============================================================

model Project {
  id           String        @id @default(uuid())
  tenantId     String
  name         String
  code         String        // PROJ-001
  description  String?
  status       ProjectStatus @default(PLANNING)
  startDate    DateTime?
  endDate      DateTime?
  budget       Decimal       @db.Decimal(18, 2) @default(0)
  actualCost   Decimal       @db.Decimal(18, 2) @default(0)
  currency     String        @default("USD")
  managerId    String?
  clientName   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  milestones   ProjectMilestone[]
  tasks        ProjectTask[]
  resources    ProjectResource[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("projects")
}

model ProjectMilestone {
  id          String          @id @default(uuid())
  projectId   String
  name        String
  description String?
  dueDate     DateTime
  status      MilestoneStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime        @default(now())

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       ProjectTask[]

  @@map("project_milestones")
}

model ProjectTask {
  id            String      @id @default(uuid())
  projectId     String
  milestoneId   String?
  parentTaskId  String?     // for subtasks
  title         String
  description   String?
  status        TaskStatus  @default(TODO)
  priority      Priority    @default(MEDIUM)
  assignedTo    String?
  estimatedHours Decimal?   @db.Decimal(6, 2)
  actualHours   Decimal?    @db.Decimal(6, 2)
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone     ProjectMilestone? @relation(fields: [milestoneId], references: [id])
  parentTask    ProjectTask? @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subTasks      ProjectTask[] @relation("TaskHierarchy")
  assignee      User?        @relation("AssignedToUser", fields: [assignedTo], references: [id])
  employeeAssignee Employee? @relation("AssignedToUser", fields: [assignedTo], references: [id])

  @@index([projectId])
  @@map("project_tasks")
}

model ProjectResource {
  id          String   @id @default(uuid())
  projectId   String
  employeeId  String
  role        String?  // Developer, Designer, QA
  allocation  Decimal  @db.Decimal(5, 2) // percentage 0-100
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@unique([projectId, employeeId])
  @@map("project_resources")
}

