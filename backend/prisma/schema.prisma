// ============================================================
// AMDOX ERP — Prisma Schema
// Database: PostgreSQL 17
// ORM: Prisma 5
// Project: AMX-ERP-2026-06
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ███████╗ ██████╗  ██╗
// ██╔════╝██╔═══██╗ ██║
// █████╗  ██║   ██║ ██║
// ██╔══╝  ██║   ██║ ██║
// ██║     ╚██████╔╝ ██║
// ╚═╝      ╚═════╝  ╚═╝
// F-01: MULTI-TENANT AUTH (SSO)
// Owner: M2
// ============================================================

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  domain      String?  @unique
  plan        PlanType @default(STARTER)
  isActive    Boolean  @default(true)
  logoUrl     String?
  settings    Json     @default("{}")  // theme, timezone, currency
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users             User[]
  roles             Role[]
  employees         Employee[]
  accounts          ChartOfAccount[]
  journalEntries    JournalEntry[]
  invoices          Invoice[]
  purchaseOrders    PurchaseOrder[]
  inventoryItems    InventoryItem[]
  vendors           Vendor[]
  projects          Project[]
  dashboards        Dashboard[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  webhooks          Webhook[]
  notificationPrefs NotificationPreference[]
  forecasts         Forecast[]
  payrollRuns       PayrollRun[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl    String?
  phone        String?
  isActive     Boolean   @default(true)
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // soft delete

  // Relations
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  userRoles         UserRole[]
  employee          Employee?
  sessions          Session[]
  createdEntries    JournalEntry[]      @relation("CreatedByUser")
  approvedInvoices  Invoice[]           @relation("ApprovedByUser")
  notifications     Notification[]
  auditLogs         AuditLog[]
  notificationPrefs NotificationPreference[]
  assignedTasks     ProjectTask[]       @relation("AssignedToUser")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // super_admin, tenant_admin, manager, viewer, custom
  description String?
  isSystem    Boolean  @default(false) // system roles can't be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model UserRole {
  id       String @id @default(uuid())
  userId   String
  roleId   String

  user     User   @relation(fields: [userId], references: [id])
  role     Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String   // finance, hr, supply_chain, project, dashboard
  action      String   // create, read, update, delete, approve
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

// ============================================================
// ███████╗██╗███╗  ██╗ █████╗ ███╗  ██╗ ██████╗███████╗
// ██╔════╝██║████╗ ██║██╔══██╗████╗ ██║██╔════╝██╔════╝
// █████╗  ██║██╔██╗██║███████║██╔██╗██║██║     █████╗
// ██╔══╝  ██║██║╚████║██╔══██║██║╚████║██║     ██╔══╝
// ██║     ██║██║ ╚███║██║  ██║██║ ╚███║╚██████╗███████╗
// ╚═╝     ╚═╝╚═╝  ╚══╝╚═╝  ╚═╝╚═╝  ╚══╝ ╚═════╝╚══════╝
// F-02: FINANCIAL LEDGER (GL)
// F-03: AP / AR AUTOMATION
// Owner: M3
// ============================================================

model ChartOfAccount {
  id           String      @id @default(uuid())
  tenantId     String
  code         String      // e.g. 1001, 2001, 4001
  name         String
  type         AccountType // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subType      String?     // Cash, Accounts Receivable, etc.
  currency     String      @default("USD")
  isActive     Boolean     @default(true)
  parentId     String?     // for hierarchical COA
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  parent            ChartOfAccount? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children          ChartOfAccount[] @relation("AccountHierarchy")
  debitEntries      JournalEntryLine[] @relation("DebitAccount")
  creditEntries     JournalEntryLine[] @relation("CreditAccount")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("chart_of_accounts")
}

model AccountingPeriod {
  id         String        @id @default(uuid())
  tenantId   String
  name       String        // e.g. "April 2026"
  startDate  DateTime
  endDate    DateTime
  status     PeriodStatus  @default(OPEN)
  closedAt   DateTime?
  closedBy   String?
  createdAt  DateTime      @default(now())

  journalEntries JournalEntry[]

  @@index([tenantId])
  @@map("accounting_periods")
}

model JournalEntry {
  id            String              @id @default(uuid())
  tenantId      String
  entryNumber   String              // JE-2026-0001
  periodId      String?
  date          DateTime
  description   String
  reference     String?             // invoice number, PO number
  status        JournalEntryStatus  @default(DRAFT)
  totalDebit    Decimal             @db.Decimal(18, 2)
  totalCredit   Decimal             @db.Decimal(18, 2)
  createdBy     String
  postedAt      DateTime?
  reversedAt    DateTime?
  reversalId    String?             // points to reversal entry
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  // Relations
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  period        AccountingPeriod?   @relation(fields: [periodId], references: [id])
  creator       User                @relation("CreatedByUser", fields: [createdBy], references: [id])
  lines         JournalEntryLine[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId, date])
  @@map("journal_entries")
}

model JournalEntryLine {
  id            String         @id @default(uuid())
  journalEntryId String
  debitAccountId  String?
  creditAccountId String?
  amount        Decimal        @db.Decimal(18, 2)
  currency      String         @default("USD")
  description   String?
  lineNumber    Int

  journalEntry  JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  debitAccount  ChartOfAccount? @relation("DebitAccount",  fields: [debitAccountId],  references: [id])
  creditAccount ChartOfAccount? @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([journalEntryId])
  @@map("journal_entry_lines")
}

model CurrencyRate {
  id         String   @id @default(uuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal @db.Decimal(18, 6)
  date         DateTime
  source       String  @default("ECB") // ECB, OpenExchangeRates
  createdAt    DateTime @default(now())

  @@unique([fromCurrency, toCurrency, date])
  @@index([date])
  @@map("currency_rates")
}

// ─── AP / AR (F-03) ──────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  type           InvoiceType   // AP (payable) or AR (receivable)
  invoiceNumber  String
  vendorId       String?       // for AP
  customerId     String?       // for AR (linked to vendor as customer)
  purchaseOrderId String?      // for 3-way matching
  amount         Decimal       @db.Decimal(18, 2)
  taxAmount      Decimal       @db.Decimal(18, 2) @default(0)
  totalAmount    Decimal       @db.Decimal(18, 2)
  currency       String        @default("USD")
  issueDate      DateTime
  dueDate        DateTime
  status         InvoiceStatus @default(DRAFT)
  ocrData        Json?         // raw OCR extracted fields
  ocrConfidence  Decimal?      @db.Decimal(5, 2) // 0-100%
  matchingStatus MatchingStatus @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  paidAt         DateTime?
  notes          String?
  attachmentUrl  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  // Relations
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  vendor         Vendor?       @relation(fields: [vendorId], references: [id])
  purchaseOrder  PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  approver       User?         @relation("ApprovedByUser", fields: [approvedBy], references: [id])
  lineItems      InvoiceLineItem[]
  payments       Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, type, status])
  @@index([tenantId, dueDate])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(18, 2)
  totalPrice  Decimal  @db.Decimal(18, 2)
  taxRate     Decimal  @db.Decimal(5, 2) @default(0)
  accountId   String?  // GL account to post to

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model Payment {
  id            String        @id @default(uuid())
  tenantId      String
  invoiceId     String
  amount        Decimal       @db.Decimal(18, 2)
  currency      String        @default("USD")
  method        PaymentMethod // BANK_TRANSFER, CHEQUE, CARD, CRYPTO
  reference     String?       // bank reference number
  paymentDate   DateTime
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())

  invoice       Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

// ============================================================
// ██╗  ██╗██████╗
// ██║  ██║██╔══██╗
// ███████║██████╔╝
// ██╔══██║██╔══██╗
// ██║  ██║██║  ██║
// ╚═╝  ╚═╝╚═╝  ╚═╝
// F-04: HR & PAYROLL ENGINE
// Owner: M4
// ============================================================

model Department {
  id          String     @id @default(uuid())
  tenantId    String
  name        String
  code        String?
  managerId   String?
  parentId    String?
  createdAt   DateTime   @default(now())

  employees   Employee[]
  parent      Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DeptHierarchy")

  @@unique([tenantId, name])
  @@map("departments")
}

model Employee {
  id              String           @id @default(uuid())
  tenantId        String
  userId          String           @unique
  employeeCode    String           // EMP-001
  departmentId    String?
  designation     String
  managerId       String?          // self-referential for org chart
  employmentType  EmploymentType   @default(FULL_TIME)
  status          EmployeeStatus   @default(ACTIVE)
  joinDate        DateTime
  terminationDate DateTime?
  // Salary
  baseSalary      Decimal          @db.Decimal(18, 2)
  currency        String           @default("USD")
  payFrequency    PayFrequency     @default(MONTHLY)
  // Personal
  dateOfBirth     DateTime?
  gender          String?
  nationality     String?
  taxId           String?
  bankAccount     String?
  bankName        String?
  bankIfsc        String?
  address         Json?
  emergencyContact Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  manager         Employee?        @relation("OrgHierarchy", fields: [managerId], references: [id])
  reportees       Employee[]       @relation("OrgHierarchy")
  leaveRequests   LeaveRequest[]
  attendances     Attendance[]
  payslips        Payslip[]
  projectResources ProjectResource[]
  taskAssignments ProjectTask[]    @relation("AssignedToUser")

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@map("employees")
}

model LeaveType {
  id              String   @id @default(uuid())
  tenantId        String
  name            String   // Annual, Sick, Maternity, Unpaid
  daysAllowedPerYear Int
  carryForward    Boolean  @default(false)
  maxCarryForward Int?
  isPaid          Boolean  @default(true)
  createdAt       DateTime @default(now())

  leaveRequests   LeaveRequest[]

  @@unique([tenantId, name])
  @@map("leave_types")
}

model LeaveRequest {
  id           String        @id @default(uuid())
  employeeId   String
  leaveTypeId  String
  startDate    DateTime
  endDate      DateTime
  totalDays    Decimal       @db.Decimal(4, 1)
  reason       String?
  status       LeaveStatus   @default(PENDING)
  approvedBy   String?
  approvedAt   DateTime?
  rejectedReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  employee     Employee      @relation(fields: [employeeId], references: [id])
  leaveType    LeaveType     @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId])
  @@map("leave_requests")
}

model Attendance {
  id           String    @id @default(uuid())
  employeeId   String
  date         DateTime  @db.Date
  clockIn      DateTime?
  clockOut     DateTime?
  totalHours   Decimal?  @db.Decimal(4, 2)
  overtimeHours Decimal? @db.Decimal(4, 2)
  status       AttendanceStatus @default(PRESENT)
  notes        String?
  createdAt    DateTime  @default(now())

  employee     Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@map("attendances")
}

model PayrollRun {
  id            String        @id @default(uuid())
  tenantId      String
  period        String        // "2026-04" (YYYY-MM)
  status        PayrollStatus @default(DRAFT)
  totalEmployees Int          @default(0)
  totalGross    Decimal       @db.Decimal(18, 2) @default(0)
  totalDeductions Decimal     @db.Decimal(18, 2) @default(0)
  totalNet      Decimal       @db.Decimal(18, 2) @default(0)
  currency      String        @default("USD")
  processedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  payslips      Payslip[]

  @@unique([tenantId, period])
  @@map("payroll_runs")
}

model Payslip {
  id              String    @id @default(uuid())
  payrollRunId    String
  employeeId      String
  basicSalary     Decimal   @db.Decimal(18, 2)
  // Allowances
  allowances      Json      @default("{}") // HRA, transport, etc.
  totalAllowances Decimal   @db.Decimal(18, 2) @default(0)
  grossSalary     Decimal   @db.Decimal(18, 2)
  // Deductions
  deductions      Json      @default("{}") // PF, tax, insurance
  totalDeductions Decimal   @db.Decimal(18, 2) @default(0)
  netSalary       Decimal   @db.Decimal(18, 2)
  currency        String    @default("USD")
  pdfUrl          String?   // generated PDF link
  createdAt       DateTime  @default(now())

  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee        Employee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}

// ============================================================
// ███████╗██╗   ██╗██████╗ ██████╗ ██╗  ██╗   ██████╗██╗  ██╗ █████╗ ██╗███╗  ██╗
// ██╔════╝██║   ██║██╔══██╗██╔══██╗██║  ╚██╗ ██╔════╝██║  ██║██╔══██╗██║████╗ ██║
// ███████╗██║   ██║██████╔╝██████╔╝██║   ╚██╗██║     ███████║███████║██║██╔██╗██║
// ╚════██║██║   ██║██╔═══╝ ██╔═══╝ ██║   ██╔╝██║     ██╔══██║██╔══██║██║██║╚████║
// ███████║╚██████╔╝██║     ██║     ███████╔╝ ╚██████╗██║  ██║██║  ██║██║██║ ╚███║
// ╚══════╝ ╚═════╝ ╚═╝     ╚═╝     ╚══════╝   ╚═════╝╚═╝  ╚═╝╚═╝  ╚═╝╚═╝╚═╝  ╚══╝
// F-05: SUPPLY CHAIN & INVENTORY
// F-06: AI DEMAND FORECASTING
// Owner: M5
// ============================================================

model Vendor {
  id            String       @id @default(uuid())
  tenantId      String
  name          String
  code          String       // VEND-001
  email         String?
  phone         String?
  website       String?
  taxId         String?
  paymentTerms  Int          @default(30) // days
  currency      String       @default("USD")
  rating        Decimal?     @db.Decimal(3, 2) // 0.00 - 5.00
  status        VendorStatus @default(ACTIVE)
  address       Json?
  bankDetails   Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]
  invoices      Invoice[]
  inventoryItems InventoryItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("vendors")
}

model PurchaseOrder {
  id              String      @id @default(uuid())
  tenantId        String
  poNumber        String      // PO-2026-0001
  vendorId        String
  requestedBy     String?
  approvedBy      String?
  status          POStatus    @default(DRAFT)
  currency        String      @default("USD")
  subtotal        Decimal     @db.Decimal(18, 2)
  taxAmount       Decimal     @db.Decimal(18, 2) @default(0)
  totalAmount     Decimal     @db.Decimal(18, 2)
  expectedDelivery DateTime?
  deliveredAt     DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  vendor          Vendor      @relation(fields: [vendorId], references: [id])
  lineItems       POLineItem[]
  goodsReceipts   GoodsReceipt[]
  invoices        Invoice[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

model POLineItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  inventoryItemId String?
  description     String
  quantity        Decimal       @db.Decimal(10, 2)
  unitPrice       Decimal       @db.Decimal(18, 2)
  totalPrice      Decimal       @db.Decimal(18, 2)
  receivedQty     Decimal       @db.Decimal(10, 2) @default(0)

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@map("po_line_items")
}

model GoodsReceipt {
  id              String        @id @default(uuid())
  purchaseOrderId String
  receivedBy      String?
  receiptDate     DateTime
  notes           String?
  createdAt       DateTime      @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  lineItems       GoodsReceiptLine[]

  @@map("goods_receipts")
}

model GoodsReceiptLine {
  id              String       @id @default(uuid())
  goodsReceiptId  String
  inventoryItemId String?
  description     String
  orderedQty      Decimal      @db.Decimal(10, 2)
  receivedQty     Decimal      @db.Decimal(10, 2)

  goodsReceipt    GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@map("goods_receipt_lines")
}

model InventoryItem {
  id             String    @id @default(uuid())
  tenantId       String
  sku            String    // SKU-001
  name           String
  description    String?
  category       String?
  unitOfMeasure  String    @default("PCS")
  costingMethod  CostingMethod @default(FIFO)
  unitCost       Decimal   @db.Decimal(18, 2)
  sellingPrice   Decimal?  @db.Decimal(18, 2)
  quantityOnHand Decimal   @db.Decimal(10, 2) @default(0)
  quantityOnOrder Decimal  @db.Decimal(10, 2) @default(0)
  reorderPoint   Decimal   @db.Decimal(10, 2) @default(0) // trigger PO
  reorderQty     Decimal   @db.Decimal(10, 2) @default(0)
  warehouseLocation String?
  preferredVendorId String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  preferredVendor Vendor?  @relation(fields: [preferredVendorId], references: [id])
  poLineItems    POLineItem[]
  forecasts      Forecast[]
  stockMovements StockMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("inventory_items")
}

model StockMovement {
  id              String         @id @default(uuid())
  inventoryItemId String
  type            MovementType   // IN, OUT, ADJUSTMENT, TRANSFER
  quantity        Decimal        @db.Decimal(10, 2)
  unitCost        Decimal?       @db.Decimal(18, 2)
  reference       String?        // PO number, invoice number
  notes           String?
  createdAt       DateTime       @default(now())

  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId, createdAt])
  @@map("stock_movements")
}

// F-06: AI Demand Forecasting
model Forecast {
  id              String    @id @default(uuid())
  tenantId        String
  inventoryItemId String
  modelType       String    @default("PROPHET") // PROPHET, LSTM
  modelVersion    String?
  forecastDate    DateTime  // date of prediction
  forecastPeriod  String    // "2026-05" month being predicted
  predictedQty    Decimal   @db.Decimal(10, 2)
  confidenceLow   Decimal?  @db.Decimal(10, 2)
  confidenceHigh  Decimal?  @db.Decimal(10, 2)
  mape            Decimal?  @db.Decimal(6, 3)  // accuracy metric
  actualQty       Decimal?  @db.Decimal(10, 2) // filled after actuals known
  createdAt       DateTime  @default(now())

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([tenantId, inventoryItemId, forecastPeriod])
  @@map("forecasts")
}

