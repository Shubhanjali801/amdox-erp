# ─────────────────────────────────────────────────────────────────────────────
# Amdox ERP — PRODUCTION environment
# Copy this to `.env` on the server:   cp .env.production.example .env
# Then fill in real values. NEVER commit the real .env.
#
# docker-compose.prod.yml reads these for:
#   • postgres/redis passwords
#   • building DATABASE_URL / REDIS_URL for the backend
#   • JWT + Gmail secrets loaded into the backend container
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Postgres container) ────────────────────────────────────────────
DB_USER=amdox
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── Redis (container) ────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── JWT (generate each: `openssl rand -hex 32`) ──────────────────────────────
JWT_SECRET=CHANGE_ME_64_char_random_hex
JWT_REFRESH_SECRET=CHANGE_ME_different_64_char_random_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Frontend + API are same-origin behind nginx, so this is mostly belt-and-braces.
# Set to your public URL once you have it (http://<EC2_PUBLIC_IP> or https://erp.amdox.in)
CORS_ORIGINS=http://localhost

# ── Password-reset email (Gmail App Password, NOT your normal password) ───────
# https://myaccount.google.com/apppasswords  (requires 2FA on the Gmail account)
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
MAIL_FROM_NAME=Amdox ERP

# ── ML service API key (optional; leave blank to disable auth) ────────────────
ML_SERVICE_API_KEY=
