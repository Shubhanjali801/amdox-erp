# ─────────────────────────────────────────────────────────────────────────────
# k3s deploy config — copy to deploy.env on the EC2 box and fill in.
#   cp deploy.env.example deploy.env  &&  nano deploy.env
# deploy-k3s.sh reads this. NEVER commit the filled-in deploy.env.
# ─────────────────────────────────────────────────────────────────────────────

# Public domain the app will be served on (A-record must point to this EC2 IP)
DOMAIN=erp.amdox.in

# Email for Let's Encrypt registration / expiry notices
LETSENCRYPT_EMAIL=you@amdox.in

# Postgres / app DB password (used for both the DB and the DATABASE_URL)
DB_PASSWORD=CHANGE_ME_strong_db_password

# JWT secrets — generate each with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_hex
JWT_REFRESH_SECRET=CHANGE_ME_different_64_hex

# Gmail App Password for password-reset emails (optional; leave blank to skip)
GMAIL_USER=
GMAIL_APP_PASSWORD=
